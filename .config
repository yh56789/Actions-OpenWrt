# This is an empty file, please overwrite it after generating the .config file with the source code
#
# Automatically generated build config for Sony VPCX118LC (Atom Z540 32bit)
# ImmortalWrt 24.10 / openwrt-24.10 x86_generic
#
CONFIG_MODULES=y
CONFIG_HAVE_DOT_CONFIG=y
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_generic=y
CONFIG_TARGET_x86_generic_DEVICE_generic=y
CONFIG_TARGET_BOARD="x86"
CONFIG_TARGET_SUBTARGET="generic"
CONFIG_TARGET_PROFILE="Default Profile"
CONFIG_TARGET_ARCH_PACKAGES="i386_pentium4"
CONFIG_DEFAULT_TARGET_OPTIMIZATION="-Os -pipe -march=pentium4 -mtune=generic"
CONFIG_CPU_TYPE="pentium4"

# Kernel
CONFIG_LINUX_6_6=y
CONFIG_KERNEL_PRINTK_TIME=y
CONFIG_KERNEL_CRASHLOG=y
# CONFIG_KERNEL_DEBUG_INFO is not set

# 固件格式与大小（BIOS专用，不启用UEFI）
CONFIG_GRUB_IMAGES=y
# CONFIG_GRUB_EFI_IMAGES is not set
CONFIG_GRUB_PCBIOS=y
CONFIG_GRUB_TITLE="ImmortalWrt for Sony VPCX118LC"
CONFIG_TARGET_ROOTFS_PARTSIZE=512
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_IMAGES_GZIP=y

# 存储与USB（适配机型USB2.0，支持U盘、外接存储）
CONFIG_PACKAGE_kmod-ata-core=y
CONFIG_PACKAGE_kmod-ahci=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-nls-utf8=y

# 有线网卡驱动（适配索尼VPCX118LC常见网卡，全覆盖）
CONFIG_PACKAGE_kmod-e1000=y
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-r8169=y
CONFIG_PACKAGE_kmod-tg3=y

# 无线网卡驱动（适配机型内置WiFi，无需额外配置）
CONFIG_PACKAGE_kmod-ath5k=y
CONFIG_PACKAGE_kmod-ath9k=y
CONFIG_PACKAGE_kmod-rt2800-usb=y
CONFIG_PACKAGE_kmod-iwlwifi=y
CONFIG_PACKAGE_iwlwifi-firmware-ax200=y
CONFIG_PACKAGE_iwlwifi-firmware-ax210=y

# 基础网络组件（保证路由正常工作）
CONFIG_PACKAGE_dnsmasq=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# 轻量常用插件（32位Atom兼容，不占用过多性能）
CONFIG_PACKAGE_luci-app-samba4=y  # 文件共享
CONFIG_PACKAGE_luci-app-upnp=y    # UPnP端口映射
CONFIG_PACKAGE_luci-app-wol=y     # 网络唤醒
CONFIG_PACKAGE_luci-app-mwan3=y   # 多线负载
CONFIG_PACKAGE_luci-app-nlbwmon=y # 流量统计
CONFIG_PACKAGE_luci-app-ttyd=y    # 网页终端
CONFIG_PACKAGE_luci-app-filetransfer=y # 文件传输

# 禁用高负载组件（避免32位Atom卡顿、编译失败）
# CONFIG_PACKAGE_docker is not set
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_luci-app-adguardhome is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
